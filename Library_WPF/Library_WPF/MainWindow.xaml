<Window x:Class="WpfLibrary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library System" Height="500" Width="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <StackPanel Grid.Column="0">

            <ComboBox x:Name="cmbType" Margin="0,0,0,10">
                <ComboBoxItem Content="Книга"/>
                <ComboBoxItem Content="Журнал"/>
            </ComboBox>

            <TextBlock Text="Название" Margin="0,0,0,5"/>
            <TextBox x:Name="txtTitle" Margin="0,0,0,10" Height="30"/>

            <TextBlock Text="Год издания" Margin="0,0,0,5"/>
            <TextBox x:Name="txtYear" Margin="0,0,0,10" Height="30"/>

            <TextBlock Text="Автор (для книги) / Выпуск (для журнала)" Margin="0,0,0,5"/>
            <TextBox x:Name="txtExtra" Margin="0,0,0,10" Height="30"/>
            
            <Button Content="Добавить" Click="BtnAdd_Click" Height="35"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Height="35" Margin="0,10,0,0"/>
            <Button Content="Статистика" Click="BtnStats_Click" Height="35"/>
            
            <Button Content="Редактировать" Click="BtnEdit_Click" Height="30"/>
        </StackPanel>

        <!-- TABLE -->
        <DataGrid x:Name="grid"
          Grid.Column="1"
          Margin="10"
          AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Тип"
                    Binding="{Binding Type}"
                    Width="100"/>
                
                
                <DataGridTextColumn Header="ID"
                            Binding="{Binding Id}"
                            Width="60"/>

                <DataGridTextColumn Header="Название"
                            Binding="{Binding Title}"
                            Width="*"/>

                <DataGridTextColumn Header="Год"
                            Binding="{Binding Year}"
                            Width="100"/>

                <DataGridTextColumn Header="Автор"
                            Binding="{Binding Author}"
                            Width="180"/>

                <DataGridTextColumn Header="Выпуск"
                            Binding="{Binding Issue}"
                            Width="100"/>

            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Window>